#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Database seeding script.
 *
 * Executes only the reference data seed file (999_seed.sql).
 * Schema creation is handled by bin/migrate (PHP migration classes).
 * Uses the PhpDb adapter pulled from the service container so that
 * the same connection configuration used by the application is applied.
 *
 * Usage (from project root):
 *   php bin/db-seed
 */

use PhpDb\Adapter\AdapterInterface;

chdir(dirname(__DIR__));

require 'vendor/autoload.php';

$container = require 'config/container.php';

/** @var AdapterInterface $adapter */
$adapter = $container->get(AdapterInterface::class);

$files = [__DIR__ . '/../data/schema/999_seed.sql'];

$ok     = 0;
$errors = 0;

foreach ($files as $file) {
    $name = basename($file);
    $sql  = file_get_contents($file);

    if ($sql === false || trim($sql) === '') {
        printf("  SKIP  %s (empty or unreadable)%s", $name, PHP_EOL);
        continue;
    }

    try {
        $adapter->query($sql, AdapterInterface::QUERY_MODE_EXECUTE);
        printf("  OK    %s%s", $name, PHP_EOL);
        $ok++;
    } catch (Throwable $e) {
        printf("  ERROR %s — %s%s", $name, $e->getMessage(), PHP_EOL);
        $errors++;
    }
}

echo PHP_EOL;
printf("Done. %d file(s) executed, %d error(s).%s", $ok, $errors, PHP_EOL);

exit($errors > 0 ? 1 : 0);
