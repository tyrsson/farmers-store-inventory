<?php

declare(strict_types=1);

use Axleus\Message\MessageLevel;

$this->headMeta()
    ->setCharSet('UTF-8')
    ->appendName('viewport', 'width=device-width, initial-scale=1')
    ->appendName('color-scheme', 'light dark');

$this->headLink(
    [
        'rel'  => 'icon',
        'type' => 'image/svg+xml',
        'href' => $this->basePath('favicon.svg'),
    ]
);

// styles
$this->headLink()
    ->prependStylesheet($this->basePath('assets/css/custom.css'))
    ->prependStylesheet('https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css')
    ->prepend([
        'crossorigin' => '',
        'href'        => 'https://fonts.gstatic.com',
        'rel'        => 'preconnect',
    ])
    ->prepend([
        'rel'  => 'preconnect',
        'href' => 'https://fonts.googleapis.com',
    ])
    ->prependStylesheet('https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css');

// head script files and script
$this->headScript()
    ->appendFile(
        'https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js',
        [
            'type'        => 'text/javascript',
            'integrity'   => 'sha384-/TgkGk7p307TH7EXJDuUlgG3Ce1UVolAOFopFekQkkXihi5u/6OCvVKyz1W+idaz',
            'crossorigin' => 'anonymous',
        ],
    )
    ->appendFile($this->basePath($this->asset('messenger.js')));

$this->inlineScript()
    ->prependFile('https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
    ->appendFile($this->basePath('assets/js/app.js'));
?>

<?= $this->doctype(); ?>

<html lang="en" data-bs-theme="dark">
    <head>
        <base href="<?= $this->basePath('/'); ?>" />
        <?= $this->headTitle('Farmers IMS')->setSeparator(' | ') ?>
        <?= $this->headMeta() ?>
        <?= $this->headLink() ?>
        <?= $this->headScript() ?>
    </head>
    <body hx-boost="true" hx-push-url="true" hx-target="main">
        <main id="app">
            <?= $this->body ?>
        </main>
        <div id="systemMessage" class="toast-container position-fixed bottom-0 end-0 p-4" aria-live="polite" aria-atomic="false"></div>
        <?= $this->inlineScript() ?>
    </body>
</html>