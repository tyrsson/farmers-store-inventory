<?php
/**
 * Manifest list page.
 *
 * Variables:
 *   $this->manifests  Ims\Manifest\Entity\Manifest[]
 *   $this->total      int
 *   $this->page       int
 *   $this->pageSize   int
 */
$this->headTitle('Manifests');
?>

<!-- Page header -->
<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h4 fw-bold mb-0">Manifests</h1>
        <p class="text-secondary small mb-0"><?= (int) $this->total ?> manifests</p>
    </div>
    <button type="button" class="btn btn-primary btn-sm"
            data-bs-toggle="modal" data-bs-target="#uploadManifestModal">
        <i class="bi bi-plus-lg me-1"></i>Upload Manifest
    </button>
</div>

<!-- Manifest list -->
<div class="d-flex flex-column gap-3 mb-4">
<?php foreach ($this->manifests as $manifest): ?>
    <?php
        $pieces  = $manifest->totalPieces();
        $damaged = $manifest->damagedLines();
    ?>
    <a href="<?= $this->url('manifest.detail', ['id' => $manifest->id]) ?>"
       class="card text-decoration-none text-body"
       hx-boost="true">
        <div class="card-body">
            <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                <div>
                    <div class="fw-bold"><?= $this->escapeHtml($manifest->displayId()) ?></div>
                    <div class="text-secondary small">
                        <?= $this->escapeHtml($manifest->receivedDate->format('M j, Y')) ?>
                        <?php if ($manifest->reference !== null): ?>
                            &middot; DC #<?= $this->escapeHtml($manifest->reference) ?>
                        <?php endif; ?>
                        &middot; <?= (int) $pieces ?> pieces
                    </div>
                </div>
                <span class="badge bg-success flex-shrink-0">Received</span>
            </div>
            <div class="ims-progress-label">
                <span><?= (int) $pieces ?> pieces</span>
                <?php if ($damaged > 0): ?>
                    <span class="text-danger">
                        <i class="bi bi-exclamation-circle"></i>
                        <?= (int) $damaged ?> damaged
                    </span>
                <?php endif; ?>
            </div>
            <div class="progress ims-progress-bar-sm" role="progressbar"
                 aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar <?= $damaged > 0 ? 'bg-warning' : 'bg-success' ?>"
                     style="width:100%"></div>
            </div>
        </div>
    </a>
<?php endforeach; ?>
<?php if ($this->manifests === []): ?>
    <div class="text-center text-secondary py-5">
        <i class="bi bi-clipboard2-data fs-1 d-block mb-2"></i>
        No manifests yet.
    </div>
<?php endif; ?>
</div>

<!-- Pagination -->
<?php if ($this->total > $this->pageSize): ?>
<?php
    $pages      = (int) ceil($this->total / $this->pageSize);
    $currentPage = (int) $this->page;
?>
<nav aria-label="Manifest pagination">
    <ul class="pagination pagination-sm justify-content-center">
        <li class="page-item <?= $currentPage <= 1 ? 'disabled' : '' ?>">
            <a class="page-link"
               href="<?= $this->url('manifest.list', [], ['query' => ['page' => $currentPage - 1]]) ?>"
               hx-boost="true">Previous</a>
        </li>
        <?php for ($p = 1; $p <= $pages; $p++): ?>
        <li class="page-item <?= $p === $currentPage ? 'active' : '' ?>">
            <a class="page-link"
               href="<?= $this->url('manifest.list', [], ['query' => ['page' => $p]]) ?>"
               hx-boost="true"><?= $p ?></a>
        </li>
        <?php endfor; ?>
        <li class="page-item <?= $currentPage >= $pages ? 'disabled' : '' ?>">
            <a class="page-link"
               href="<?= $this->url('manifest.list', [], ['query' => ['page' => $currentPage + 1]]) ?>"
               hx-boost="true">Next</a>
        </li>
    </ul>
</nav>
<?php endif; ?>

<!-- Upload Manifest Modal -->
<div class="modal fade" id="uploadManifestModal" tabindex="-1"
     aria-labelledby="uploadManifestModalLabel" aria-hidden="true"
     data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="uploadManifestModalLabel">
                    <i class="bi bi-file-earmark-spreadsheet me-2"></i>Upload DC Truck Manifest
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post"
                  action="<?= $this->url('manifest.upload.store') ?>"
                  enctype="multipart/form-data"
                  novalidate>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="manifest_csv" class="form-label fw-semibold">
                            Manifest CSV File <span class="text-danger">*</span>
                        </label>
                        <input type="file"
                               class="form-control"
                               id="manifest_csv"
                               name="manifest_csv"
                               accept=".csv,text/csv,text/plain"
                               required>
                        <div class="form-text">
                            Select the CSV file exported from the DC system
                            (e.g. <em>Dist DC Truck Manifest - Live.csv</em>).
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="received_date" class="form-label fw-semibold">
                            Received Date Override
                        </label>
                        <input type="date"
                               class="form-control"
                               id="received_date"
                               name="received_date">
                        <div class="form-text">
                            Defaults to the date in the consignment header. Override only if
                            the truck arrived on a different calendar day.
                        </div>
                    </div>
                    <p class="text-secondary small mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Customer allocation rows are automatically skipped. Unknown SKUs and major codes
                        will be added to the catalogue and can be updated later from Settings.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload me-1"></i>Import Manifest
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
