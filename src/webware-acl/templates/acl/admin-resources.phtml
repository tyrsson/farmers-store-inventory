                >
                    <div class="d-flex align-items-center gap-2 flex-grow-1 me-3">
                        <code class="text-primary"><?= $this->escapeHtml($resource->resourceId) ?></code>
                        <span class="text-secondary small"><?= $this->escapeHtml($resource->label) ?></span>
                        <span class="badge bg-body-tertiary border text-secondary ms-auto ims-badge-xs">
                            <?= $privCount ?> <?= $privCount === 1 ? 'privilege' : 'privileges' ?>
                        </span>
                    </div>
                </button>
                <div class="d-flex align-items-center align-self-stretch border-start bg-body px-2 flex-shrink-0">
                    <?php if ($resource->system): ?>
