</div>

<?php if ($this->resources === []): ?>
    <div class="text-secondary small mt-3">No resources defined yet.</div>
<?php endif; ?>

<!-- Unprotected Routes -->
<?php if (isset($this->unprotected) && $this->unprotected !== []): ?>
<?php
    $methodPrivilegeMap = [
        'GET'    => 'read',
        'POST'   => 'create',
        'PUT'    => 'update',
        'PATCH'  => 'update',
        'DELETE' => 'delete',
    ];
    $privilegeColor = [
        'read'   => 'primary',
        'create' => 'success',
        'update' => 'warning',
        'delete' => 'danger',
    ];
    $unprotectedCount = count($this->unprotected);
?>
<div class="card border-warning mt-4 mb-4">
    <div class="card-header d-flex align-items-center gap-2 py-2">
        <i class="bi bi-shield-exclamation text-warning"></i>
        <span class="fw-semibold small">Unprotected Routes</span>
        <span class="badge bg-warning text-dark ms-auto"><?= $unprotectedCount ?></span>
    </div>
    <div class="accordion accordion-flush" id="unprotectedAccordion">
        <?php foreach ($this->unprotected as $routeName => $methods):
            $accId = 'uprec-' . preg_replace('/[^a-z0-9]+/', '-', strtolower($routeName));
            $privileges = array_unique(array_filter(array_map(
                static fn(string $m): string => $methodPrivilegeMap[$m] ?? '',
                $methods,
            )));
        ?>
        <div class="accordion-item" id="<?= $this->escapeHtmlAttr($accId) ?>">
            <h2 class="accordion-header">
                <button
                    class="accordion-button collapsed py-2"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#<?= $this->escapeHtmlAttr($accId) ?>-body"
                    aria-expanded="false"
                    aria-controls="<?= $this->escapeHtmlAttr($accId) ?>-body"
                >
                    <div class="d-flex align-items-center gap-2 flex-grow-1 me-2">
                        <code class="small"><?= $this->escapeHtml($routeName) ?></code>
                        <div class="d-flex gap-1 ms-auto">
                            <?php foreach ($privileges as $priv): ?>
                                <span class="badge bg-transparent border border-<?= $privilegeColor[$priv] ?> text-<?= $privilegeColor[$priv] ?> ims-badge-xs">
                                    <?= ucfirst($priv) ?>
                                </span>
                            <?php endforeach; ?>
                        </div>
                    </div>
                </button>
            </h2>
            <div id="<?= $this->escapeHtmlAttr($accId) ?>-body" class="accordion-collapse collapse">
                <div class="accordion-body py-2 px-3">
                    <form
                        hx-post="<?= $this->url('admin.acl.resources.protect') ?>"
                        hx-target="main"
                        hx-swap="innerHTML"
                    >
                        <input type="hidden" name="routeName" value="<?= $this->escapeHtmlAttr($routeName) ?>">
                        <p class="small text-secondary mb-2">Select role(s) to grant access:</p>
                        <div class="d-flex flex-wrap gap-3 mb-3">
                            <?php foreach ($this->roles as $role):
                                $cbId = $accId . '-r-' . preg_replace('/[^a-z0-9]+/', '-', strtolower($role->roleId));
                            ?>
                            <div class="form-check">
                                <input
                                    class="form-check-input"
                                    type="checkbox"
                                    name="role[]"
                                    value="<?= $this->escapeHtmlAttr($role->roleId) ?>"
                                    id="<?= $this->escapeHtmlAttr($cbId) ?>"
                                >
                                <label class="form-check-label small" for="<?= $this->escapeHtmlAttr($cbId) ?>">
                                    <?= $this->escapeHtml($role->roleId) ?>
                                </label>
                            </div>
                            <?php endforeach; ?>
                        </div>
                        <button type="submit" class="btn btn-sm btn-warning py-1 px-3">
                            <i class="bi bi-shield-plus me-1"></i> Protect
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <?php endforeach; ?>
    </div>
</div>
<?php endif; ?>


