                            <i class="bi bi-lock"></i>
                        </button>
                    <?php else: ?>
                        <button
                            type="button"
                            class="btn btn-sm btn-outline-danger py-0 px-2"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteResourceModal"
                            data-resource-pk="<?= $resource->resourcePk ?>"
                            data-resource-id="<?= $this->escapeHtmlAttr($resource->resourceId) ?>"
                            title="Delete resource"
                        >
                            <i class="bi bi-trash3"></i>
                        </button>
                    <?php endif; ?>
                </div>
            </h2>
            <div
                id="<?= $this->escapeHtmlAttr($accordionId) ?>"
