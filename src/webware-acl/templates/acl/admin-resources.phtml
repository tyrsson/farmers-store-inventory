                                <?php foreach ($resourcePrivs as $priv): ?>
                                    <tr>
                                        <td><code><?= $this->escapeHtml($priv->privilegeId) ?></code></td>
                                        <td class="text-secondary small"><?= $this->escapeHtml($priv->label) ?></td>
