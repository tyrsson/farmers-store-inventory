<?php $this->inlineScript()->captureStart(); ?>
(function () {
    // Add modal — pre-fill route name when triggered from an Unmapped row
    document.getElementById('addMappingModal')?.addEventListener('show.bs.modal', function (e) {
        const trigger   = e.relatedTarget;
        const routeName = trigger?.dataset.route ?? '';
        const input     = document.getElementById('new_route_name');
        if (input && routeName) {
            input.value    = routeName;
            input.readOnly = true;
        } else if (input) {
            input.value    = '';
            input.readOnly = false;
        }
    });

    // Edit modal — populate fields from data attributes
    document.getElementById('editMappingModal')?.addEventListener('show.bs.modal', function (e) {
        const trigger   = e.relatedTarget;
        const routeName = trigger?.dataset.route     ?? '';
        const resource  = trigger?.dataset.resource  ?? '';
        const privilege = trigger?.dataset.privilege ?? '';

        const nameInput = document.getElementById('edit_route_name');
        if (nameInput) nameInput.value = routeName;

        const resourceSel = document.getElementById('edit_resource_id');
        if (resourceSel) {
            for (const opt of resourceSel.options) {
                opt.selected = opt.text === resource;
            }
        }

        const privilegeSel = document.getElementById('edit_privilege_id');
        if (privilegeSel) {
            for (const opt of privilegeSel.options) {
                opt.selected = opt.text === privilege;
            }
        }
    });

    // Delete modal — populate route name and set hx-delete URL
    document.getElementById('deleteMappingModal')?.addEventListener('show.bs.modal', function (e) {
        const trigger   = e.relatedTarget;
        const routeName = trigger?.dataset.route ?? '';
        const label     = document.getElementById('deleteRouteName');
        const btn       = document.getElementById('deleteMappingConfirmBtn');
        if (label) label.textContent = routeName;
        if (btn)   btn.setAttribute('hx-delete', '/admin/access/routes/' + encodeURIComponent(routeName));
        htmx.process(btn);
    });
}());
<?php $this->inlineScript()->captureEnd(); ?>
