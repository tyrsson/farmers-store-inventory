    <div class="card-body py-3">
        <?php
        /**
         * Build a tree from $roles + $roleParents for display.
         * $roleParents is keyed by child PK → array of parent PKs.
         * We find root roles (no parents) and recurse.
         */
        $childrenOf = [];
        foreach ($this->roleParents as $childPk => $parentPks) {
            foreach ($parentPks as $parentPk) {
                $childrenOf[$parentPk][] = $childPk;
            }
        }
        $rootPks = [];
        foreach ($this->roles as $pk => $role) {
            if (($this->roleParents[$pk] ?? []) === []) {
                $rootPks[] = $pk;
            }
        }
        $renderTree = static function (int $pk, int $depth) use (&$renderTree, $childrenOf, $roles): void {
            $indent = str_repeat('&nbsp;&nbsp;&nbsp;&nbsp;', $depth);
            $prefix = $depth > 0 ? '└── ' : '';
            $role   = $roles[$pk];
            echo '<div style="font-size:.875rem; font-family:monospace;">';
            echo $indent . $prefix . '<span class="text-body">' . htmlspecialchars($role->roleId, ENT_QUOTES) . '</span>';
            if ($depth === 0) {
                echo ' <span class="badge bg-body-tertiary border text-secondary ms-1" style="font-size:.65rem;">root</span>';
            }
            echo '</div>';
            foreach ($childrenOf[$pk] ?? [] as $childPk) {
                $renderTree($childPk, $depth + 1);
            }
        };
        $roles = $this->roles;
        foreach ($rootPks as $rootPk) {
            $renderTree($rootPk, 0);
        }
        ?>
    </div>
</div>

