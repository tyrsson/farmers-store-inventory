<!-- REDUNDANCY WARNING MODAL -->
<!-- Shown client-side (no round-trip) when JS detects the role being granted
     a rule is an ancestor of one or more roles that already have an explicit
     rule for the same resource + privilege, or has descendants with no rule
     that will silently gain access via the chain walk-up. -->
<div class="modal fade" id="redundancyWarningModal" tabindex="-1" aria-labelledby="redundancyWarningModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header py-2 border-warning">
                <h5 class="modal-title small fw-bold text-warning-emphasis" id="redundancyWarningModalLabel">
                    <i class="bi bi-exclamation-triangle me-1"></i> Redundancy Notice
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body small">
                <p class="mb-2">
                    You are adding an explicit <strong id="redundancyRuleType" class="text-success">allow</strong>
                    on <code id="redundancyTargetRole"></code> for
                    <code id="redundancyResource"></code> → <code id="redundancyPrivilege"></code>.
                    Because the ACL walks <em>up</em> the chain from child to parent,
                    this affects every descendant role that has no explicit rule of its own.
                </p>

                <!-- Section 1 — Privilege elevation (the security-critical warning) -->
                <div id="redundancyElevationSection" class="alert alert-warning py-2 px-3 mb-3" role="alert">
                    <div class="fw-semibold mb-1">
                        <i class="bi bi-shield-exclamation me-1"></i>
                        Privilege elevation — these roles will gain access
                    </div>
                    <p class="mb-2 text-warning-emphasis">
                        The following descendant roles currently have <strong>no rule</strong>
                        for this privilege. Once this rule is added they will resolve
                        <strong>allow</strong> via the chain walk-up. Confirm you intend
                        to grant them access.
                    </p>
                    <div id="redundancyElevatedList" class="d-flex flex-wrap gap-1"></div>
                </div>

                <!-- Section 2 — Redundancy notice (informational only) -->
                <div id="redundancyRedundantSection" class="mb-2">
                    <div class="fw-semibold mb-1 text-secondary">
                        <i class="bi bi-info-circle me-1"></i>
                        Redundant — these roles are unaffected
                    </div>
                    <p class="text-secondary mb-2">
                        The following descendant roles already have their own explicit rule.
                        It is found first during the walk-up, so this new rule has no effect
                        for them. Their rule is not changed.
                    </p>
                    <div id="redundancyDescendantList" class="d-flex flex-wrap gap-1"></div>
                </div>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-warning" id="redundancyConfirmBtn">
                    <i class="bi bi-exclamation-triangle me-1"></i> Add Rule Anyway
                </button>
            </div>
        </div>
    </div>
</div>

