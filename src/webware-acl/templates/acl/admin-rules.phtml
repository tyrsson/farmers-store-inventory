<?php $this->inlineScript()->captureStart(); ?>
(function () {
    // Populate rule id when Add Assertion modal opens
    document.getElementById('addAssertionModal')?.addEventListener('show.bs.modal', function (e) {
        const trigger = e.relatedTarget;
        const ruleId  = trigger ? (trigger.dataset.ruleId ?? '') : '';
        document.getElementById('assertionRuleId').value = ruleId;
        document.getElementById('assertionFqcn').value   = '';
        document.getElementById('assertionSortOrder').value = '0';
        document.querySelector('input[name="assertionMode"][value="all"]').checked = true;
    });

    // Confirm — POST to /admin/access/rules/{rule_id}/assertions
    document.getElementById('addAssertionConfirmBtn')?.addEventListener('click', function () {
        const ruleId    = document.getElementById('assertionRuleId').value;
        const assertion = document.getElementById('assertionFqcn').value.trim();
        const mode      = document.querySelector('input[name="assertionMode"]:checked')?.value ?? 'all';
        const sortOrder = document.getElementById('assertionSortOrder').value;

        if (!ruleId || !assertion) return;

        htmx.ajax('POST', '/admin/access/rules/' + ruleId + '/assertions', {
            target: 'main',
            swap: 'innerHTML',
            values: { assertion: assertion, mode: mode, sort_order: sortOrder },
        });

        bootstrap.Modal.getInstance(document.getElementById('addAssertionModal'))?.hide();
    });

    // Delete assertion — delegated handler for ims-assertion-delete links
    document.addEventListener('click', function (e) {
        const link = e.target.closest('.ims-assertion-delete');
        if (!link) return;
        e.preventDefault();

        const assertionId = link.dataset.assertionId;
        const ruleId      = link.dataset.ruleId;
        if (!assertionId || !ruleId) return;

        htmx.ajax('DELETE', '/admin/access/rules/' + ruleId + '/assertions/' + assertionId, {
            target: 'main',
            swap: 'innerHTML',
        });
    });
}());
<?php $this->inlineScript()->captureEnd(); ?>
