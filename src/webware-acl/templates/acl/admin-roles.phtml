<!-- Role table -->
<div class="card">
    <div class="card-header py-2 d-flex align-items-center gap-2">
        <i class="bi bi-people text-secondary"></i>
        <span class="small fw-semibold">All Roles</span>
        <span class="badge bg-body-tertiary border text-secondary ms-1"><?= count($this->roles) ?></span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover table-sm mb-0 align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width:38%">Role Name</th>
                    <th style="width:40%">Inherits From</th>
                    <th style="width:22%"></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($this->roles as $pk => $role):
                    $parentPks   = $this->roleParents[$pk] ?? [];
                    $parentNames = array_filter(
                        array_map(fn(int $ppk) => $this->roles[$ppk]->roleId ?? null, $parentPks)
                    );
                    $isRoot = $parentPks === [];
                ?>
                    <tr>
                        <td class="fw-semibold"><?= $this->escapeHtml($role->roleId) ?></td>
                        <td class="small text-secondary">
                            <?php if ($isRoot): ?>
                                <span class="fst-italic">— root role</span>
                            <?php else: ?>
                                <?= $this->escapeHtml(implode(', ', $parentNames)) ?>
                            <?php endif; ?>
                        </td>
                        <td class="text-end">
                            <?php if ($isRoot): ?>
                                <button class="btn btn-sm btn-outline-secondary py-0 px-2" disabled title="Root role — cannot edit">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            <?php else: ?>
                                <button
                                    class="btn btn-sm btn-outline-secondary py-0 px-2"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editRoleModal"
                                    data-role-pk="<?= $pk ?>"
                                    data-role-id="<?= $this->escapeHtmlAttr($role->roleId) ?>"
                                    data-parent-id="<?= $this->escapeHtmlAttr((string) ($parentPks[0] ?? '')) ?>"
                                    data-user-count="0"
                                >
                                    <i class="bi bi-pencil"></i>
                                </button>
                            <?php endif; ?>
                        </td>
                    </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>
    <div class="card-footer py-2 text-secondary small">
        Changes to roles increment <code>acl_version</code> and invalidate the ACL cache on next request.
    </div>
</div>

