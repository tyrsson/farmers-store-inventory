{
    "name": "webware/admin",
    "description": "Mezzio admin dashboard framework: widget system, ACL-filtered rendering, and navigation for the webware-* package family.",
    "license": "BSD-3-Clause",
    "keywords": [
        "webware",
        "admin",
        "mezzio",
        "dashboard"
    ],
    "authors": [
        {
            "name": "Joey Smith",
            "email": "jsmith@webinertia.net",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0 || ~8.6.0",
        "laminas/laminas-diactoros": "^3.8",
        "laminas/laminas-permissions-acl": "^2.16",
        "mezzio/mezzio": "^3.26",
        "mezzio/mezzio-authentication": "^1.13",
        "mezzio/mezzio-router": "^3.15",
        "mezzio/mezzio-template": "^2.8",
        "psr/container": "^2.0",
        "psr/event-dispatcher": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "webware/acl": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "webware/coding-standard": "^0.1.0"
    },
    "autoload": {
        "psr-4": {
            "Webware\\Admin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webware\\AdminTest\\": "test/unit/",
            "Webware\\AdminIntegrationTest\\": "test/integration/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
